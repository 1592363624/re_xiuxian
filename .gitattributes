# Git attributes - ensure consistent file handling across platforms
# Avoid line ending and encoding issues (Ubuntu CI -> Windows server)

# Auto detect text files and normalise line endings
* text=auto

# PowerShell scripts: keep CRLF (Windows native)
*.ps1 text eol=crlf
*.bat text eol=crlf

# Shell scripts: keep LF (Linux native)
*.sh text eol=lf

# JavaScript/TypeScript/Vue: keep LF (cross-platform)
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
