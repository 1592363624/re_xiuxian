# AI 大模型配置
# 在这里配置你的 AI API Key

# 小米 MiMo API Key（推荐！免费额度充足）
# 获取地址: https://platform.xiaomimimo.com/
AI_API_KEY=your_xiaomi_mimo_api_key_here
AI_PROVIDER=xiaomi
AI_MODEL=mimo-v2-flash
AI_BASE_URL=https://api.xiaomimimo.com/v1

# OpenAI API Key（备选）
# AI_API_KEY=your_openai_api_key_here
# AI_PROVIDER=openai
# AI_MODEL=gpt-3.5-turbo
# AI_BASE_URL=https://api.openai.com/v1

# Claude API Key（备选）
# AI_API_KEY=your_anthropic_api_key_here
# AI_PROVIDER=anthropic
# AI_MODEL=claude-3-sonnet-20240229
# AI_BASE_URL=https://api.anthropic.com/v1

# 通义千问 API Key（备选）
# AI_API_KEY=your_qwen_api_key_here
# AI_PROVIDER=qwen
# AI_MODEL=qwen-turbo
# AI_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 数据库配置
DB_HOST=your_db_host_here
DB_PORT=3306
DB_NAME=your_db_name_here
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here

# 服务器配置
PORT=5000
NODE_ENV=development

# JWT 密钥
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# AI 配置加密密钥（用于 GM 后台存储 AI API Key 的 AES-256-CBC 加密）
# 必须为 64 位十六进制字符串（32 字节），生产环境请使用强随机密钥
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AI_CONFIG_ENCRYPTION_KEY=replace_with_your_64_hex_chars_key_32_bytes_random
